Algoritmo "Olá Mundo!"

Var
// Seção de Declarações das variáveis 
   nome: caractere
   idade: inteiro

Inicio
// Seção de Comandos, procedimento, funções, operadores, etc... 
   escreva ("Nome:")
   leia (nome)
   escreva ("idade:")
   leia (idade)
   escreva ("cadastrado")

Fimalgoritmo