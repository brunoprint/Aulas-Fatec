Algoritmo "soma"

Var
// Seção de Declarações das variáveis 
   num1: inteiro
   num2: inteiro
   soma: inteiro

Inicio
// Seção de Comandos, procedimento, funções, operadores, etc... 
   escreva("digite um numero: ")
   leia (num1)
   escreva("digite outro numero: ")
   leia (num2)
   soma <- num1 + num2
   escreva("a soma dos numeros é: ", soma)
Fimalgoritmo