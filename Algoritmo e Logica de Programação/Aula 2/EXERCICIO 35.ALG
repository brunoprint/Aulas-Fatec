Algoritmo "exercicio 35"

Var
   L:caracter


Inicio
      escreva ("escreva uma letra aleatória: ")
      leia(L)
      se (L = "a") OU (L = "A") entao
         escreva("Azul")
      senao
           se (L = "v") OU (L = "V") entao
              escreva("Vermelho")
           senao
              escreva("Cor invalida")
           fimse
      fimse

      


Fimalgoritmo