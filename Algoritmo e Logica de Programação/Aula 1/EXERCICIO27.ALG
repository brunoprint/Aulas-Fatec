Algoritmo "EXERCICIO27"

Var
   N1:inteiro
   N2:inteiro
   Re:inteiro


Inicio
      escreva("digite um numero: ")
      leia(N1)
      escreva("digite outro numero: ")
      leia(N2)
      Re <- N1*N2
      
      se(Re>=50) entao
      escreva("a multiplicaçăo desses valores săo de:", Re)
      fimse


Fimalgoritmo