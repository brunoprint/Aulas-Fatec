Algoritmo "semnome"
// 
//  
// Descrição   : Aqui você descreve o que o programa faz! (função)
// Autor(a)    : Nome do(a) aluno(a)
// Data atual  : 01/04/2026
Var
   num:inteiro

Inicio
      num <- 1
      enquanto num <= 49 faca
               escreva (num)
               num <- num + 2
      fimenquanto


Fimalgoritmo