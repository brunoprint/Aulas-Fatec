Algoritmo "EXERCICIO28"

Var
   N1:REAL


Inicio
      escreva("digite um numero: ")
      leia(N1)
      se(N1=0)entao
      escreva("numero nulo")
      senao
           se(N1>0)entao
           escreva("numero positivo")
           senao
           escreva("numero negativo")
           fimse
      fimse


Fimalgoritmo